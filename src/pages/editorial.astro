---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Editorial Team | latepaycalc.com';
const description = 'Meet the editorial team behind latepaycalc.com.';
---
<BaseLayout title={title} description={description}>
  <h1>Editorial Team</h1>
  <p>latepaycalc.com is written and reviewed by The Click Lab's editorial team. We verify formulas against state statutes and the Restatement of Contracts.</p>
  <h2>Editorial standards</h2>
  <ul>
    <li>Cite the authority (statute, regulation, leading case)</li>
    <li>No legal or financial advice &mdash; informational only</li>
    <li>No paid placements or recommended-firm lists</li>
  </ul>
  <h2>Corrections</h2>
  <p>Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
