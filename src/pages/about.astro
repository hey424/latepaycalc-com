---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About latepaycalc.com';
const description = 'About the team behind latepaycalc.com. Free late-payment calculators and guides for both B2B invoices and employment final paychecks.';
---
<BaseLayout title={title} description={description}>
  <h1>About latepaycalc.com</h1>
  <p>latepaycalc.com is a free late-payment resource maintained by The Click Lab. Our calculator handles two common scenarios: B2B invoice late fees and employment final-paycheck penalties.</p>
  <h2>What we do</h2>
  <p>We provide calculator math and plain-English guidance for two distinct late-payment contexts. Every page is reviewed by our <a href="/editorial">editorial team</a> with citations to relevant state statutes and case law.</p>
  <h2>What we don't do</h2>
  <p>We don't provide legal or financial advice. Specific disputes depend on your contract, jurisdiction, and procedural posture. For meaningful sums, consult a licensed attorney.</p>
  <h2>How we make money</h2>
  <p>Display advertising via Google AdSense. We don't sell reader data or accept paid placements. See <a href="/privacy">privacy policy</a>.</p>
  <h2>Contact</h2>
  <p>See our <a href="/contact">contact page</a>.</p>
</BaseLayout>
