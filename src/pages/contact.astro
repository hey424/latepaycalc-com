---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | latepaycalc.com';
const description = 'Contact latepaycalc.com for questions, corrections, or feedback.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
  <h2>What we respond to</h2>
  <ul>
    <li>Corrections to calculator math or statute citations</li>
    <li>Errors or unclear language in guides</li>
    <li>Suggestions for new content</li>
  </ul>
  <h2>What we don't respond to</h2>
  <p>We can't evaluate your specific dispute or recommend specific attorneys. For your situation, contact a licensed attorney in your state.</p>
</BaseLayout>
